    RowBox[{
     SubscriptBox["w", "1"], " ", 
     SubscriptBox["i", "1"]}], "+", 
    RowBox[{
     SubscriptBox["w", "2"], " ", 
     SubscriptBox["i", "2"]}], "+", 
    SubscriptBox["b", "1"]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SubscriptBox["out", "h1"], "=", 
   RowBox[{"sigmoid", "[", 
    SubscriptBox["net", "h1"], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
