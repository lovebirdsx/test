 RowBox[{
  RowBox[{
   SubscriptBox["i", "1"], "=", ".05"}], ";", 
  RowBox[{
   SubscriptBox["i", "2"], "=", ".10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SubscriptBox["b", "1"], "=", ".35"}], ";", 
  RowBox[{
   SubscriptBox["b", "2"], "=", ".60"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SubscriptBox["target", "o1"], "=", "0.01"}], ";", 
  RowBox[{
   SubscriptBox["target", "o2"], "=", "0.99"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SubscriptBox["net", "h1"], "=", 
