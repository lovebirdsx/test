Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"sigmoid", "[", "x_", "]"}], "=", 
   FractionBox["1", 
    RowBox[{"1", "+", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"-", "x"}]]}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SubscriptBox["w", "1"], "=", ".15"}], ";", 
  RowBox[{
   SubscriptBox["w", "2"], "=", ".20"}], ";", 
  RowBox[{
   SubscriptBox["w", "3"], "=", ".25"}], ";", 
  RowBox[{
   SubscriptBox["w", "4"], "=", ".30"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
